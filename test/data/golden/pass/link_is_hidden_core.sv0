/* Surrogate for link.sml isHidden: dot-prefix file classification.
   SML reference: sml/link/link.sml lines 6-8
     fun isHidden (name : string) : bool =
       name = "." orelse name = ".."
       orelse (String.size name > 0 andalso String.sub (name, 0) = #".")
   Note: "." and ".." are directory entries, NOT hidden.
   Uses string intrinsics: string_eq, string_len, string_char_at. */

fn is_hidden(name: string) -> bool {
    if string_eq(name, ".") { return false; }
    if string_eq(name, "..") { return false; }
    let len: i32 = string_len(name);
    if len == 0 { return false; }
    let first: i32 = string_char_at(name, 0);
    if first == 46 { return true; }
    return false;
}

fn main() -> i32 {
    if is_hidden(".") != false { return 1; }
    if is_hidden("..") != false { return 2; }

    if is_hidden(".gitignore") != true { return 3; }
    if is_hidden(".hidden") != true { return 4; }
    if is_hidden(".a") != true { return 5; }

    if is_hidden("README.md") != false { return 6; }
    if is_hidden("main.sv0") != false { return 7; }
    if is_hidden("a") != false { return 8; }
    if is_hidden("") != false { return 9; }

    return 0;
}
