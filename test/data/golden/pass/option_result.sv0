enum Option<T> { Some(T), None }
enum Result<T, E> { Ok(T), Err(E) }

fn try_option(o: Option) -> Option {
    let val: i32 = o?;
    return Option::Some(val + 1);
}

fn try_result(r: Result) -> Result {
    let val: i32 = r?;
    return Result::Ok(val * 2);
}

fn main() -> i32 {
    let s: Option = Option::Some(10);
    let n: Option = Option::None;

    let v1: i32 = match s {
        Option::Some(x) => x,
        Option::None => 0,
    };
    if v1 != 10 { return 1; };

    let r1: Option = try_option(s);
    let r1v: i32 = match r1 {
        Option::Some(x) => x,
        Option::None => 0,
    };
    if r1v != 11 { return 2; };

    let r2: Option = try_option(n);
    let is_none: bool = match r2 {
        Option::Some(x) => false,
        Option::None => true,
    };
    if !is_none { return 3; };

    let ok: Result = Result::Ok(21);
    let rr1: Result = try_result(ok);
    let rr1v: i32 = match rr1 {
        Result::Ok(x) => x,
        Result::Err(e) => e,
    };
    if rr1v != 42 { return 4; };

    return 0;
}
