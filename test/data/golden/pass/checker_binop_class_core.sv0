/* Surrogate for checker.sml binopClass: binop kind classification.
   SML reference: sml/type_checker/checker.sml lines 308-315
     datatype binopKind = Arith | Logic | Cmp
     fun binopClass (b : Ast.binop) : binopKind =
       case b of
         (Add|Sub|Mul|Div|Rem|BitAnd|BitOr|BitXor|Shl|Shr) => Arith
       | (And|Or) => Logic
       | (Eq|Neq|Lt|Gt|Leq|Geq) => Cmp
   Uses Ast.Binop tags: Add=0..Geq=17 (18 total from ast.sv0). */

fn binop_class(op_tag: i32) -> i32 {
    if op_tag == 0 { return 0; }
    if op_tag == 1 { return 0; }
    if op_tag == 2 { return 0; }
    if op_tag == 3 { return 0; }
    if op_tag == 4 { return 0; }
    if op_tag == 5 { return 0; }
    if op_tag == 6 { return 0; }
    if op_tag == 7 { return 0; }
    if op_tag == 8 { return 0; }
    if op_tag == 9 { return 0; }
    if op_tag == 10 { return 1; }
    if op_tag == 11 { return 1; }
    if op_tag == 12 { return 2; }
    if op_tag == 13 { return 2; }
    if op_tag == 14 { return 2; }
    if op_tag == 15 { return 2; }
    if op_tag == 16 { return 2; }
    if op_tag == 17 { return 2; }
    return 255;
}

fn binop_returns_bool(op_tag: i32) -> bool {
    let kind: i32 = binop_class(op_tag);
    if kind == 1 { return true; }
    if kind == 2 { return true; }
    return false;
}

fn binop_is_arith(op_tag: i32) -> bool {
    return binop_class(op_tag) == 0;
}

fn main() -> i32 {
    if binop_class(0) != 0 { return 1; }
    if binop_class(1) != 0 { return 2; }
    if binop_class(2) != 0 { return 3; }
    if binop_class(3) != 0 { return 4; }
    if binop_class(4) != 0 { return 5; }
    if binop_class(5) != 0 { return 6; }
    if binop_class(6) != 0 { return 7; }
    if binop_class(7) != 0 { return 8; }
    if binop_class(8) != 0 { return 9; }
    if binop_class(9) != 0 { return 10; }

    if binop_class(10) != 1 { return 11; }
    if binop_class(11) != 1 { return 12; }

    if binop_class(12) != 2 { return 13; }
    if binop_class(13) != 2 { return 14; }
    if binop_class(14) != 2 { return 15; }
    if binop_class(15) != 2 { return 16; }
    if binop_class(16) != 2 { return 17; }
    if binop_class(17) != 2 { return 18; }

    if binop_class(99) != 255 { return 19; }

    if binop_returns_bool(0) != false { return 20; }
    if binop_returns_bool(10) != true { return 21; }
    if binop_returns_bool(12) != true { return 22; }

    if binop_is_arith(0) != true { return 23; }
    if binop_is_arith(10) != false { return 24; }
    if binop_is_arith(12) != false { return 25; }

    return 0;
}
