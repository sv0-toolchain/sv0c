/* Phase 1 type definitions: sml/error/span.sml -> sv0.
   Pos holds source position (line, column, byte offset).
   Span holds file path + start/stop positions.
   Span fields are flattened (no nested Pos struct) because the VM
   codegen does not yet support multi-slot sub-struct fields. The
   accessor functions preserve the Pos abstraction for callers. */

struct Pos {
    line: i32,
    col: i32,
    offset: i32,
}

struct Span {
    file: string,
    start_line: i32,
    start_col: i32,
    start_offset: i32,
    stop_line: i32,
    stop_col: i32,
    stop_offset: i32,
}

fn pos_new(l: i32, c: i32, off: i32) -> Pos {
    return Pos { line: l, col: c, offset: off };
}

fn span_new(f: string, s: Pos, e: Pos) -> Span {
    return Span {
        file: f,
        start_line: s.line, start_col: s.col, start_offset: s.offset,
        stop_line: e.line, stop_col: e.col, stop_offset: e.offset,
    };
}

fn span_bogus() -> Span {
    let z: Pos = pos_new(0, 0, 0);
    return span_new("", z, z);
}

fn pos_line(p: Pos) -> i32 {
    return p.line;
}

fn pos_col(p: Pos) -> i32 {
    return p.col;
}

fn pos_offset(p: Pos) -> i32 {
    return p.offset;
}

fn span_file(sp: Span) -> string {
    return sp.file;
}

fn span_start(sp: Span) -> Pos {
    return pos_new(sp.start_line, sp.start_col, sp.start_offset);
}

fn span_stop(sp: Span) -> Pos {
    return pos_new(sp.stop_line, sp.stop_col, sp.stop_offset);
}

fn span_length(sp: Span) -> i32 {
    return sp.stop_offset - sp.start_offset;
}

fn main() -> i32 {
    let p1: Pos = pos_new(1, 5, 10);
    if pos_line(p1) != 1 { return 1; }
    if pos_col(p1) != 5 { return 2; }
    if pos_offset(p1) != 10 { return 3; }

    let p2: Pos = pos_new(3, 12, 45);
    let sp: Span = span_new("test.sv0", p1, p2);
    let s: Pos = span_start(sp);
    if pos_line(s) != 1 { return 4; }
    if pos_col(s) != 5 { return 5; }
    let e: Pos = span_stop(sp);
    if pos_line(e) != 3 { return 6; }
    if pos_col(e) != 12 { return 7; }

    let len: i32 = span_length(sp);
    if len != 35 { return 8; }

    let bog: Span = span_bogus();
    let bs: Pos = span_start(bog);
    if pos_line(bs) != 0 { return 9; }
    if pos_col(bs) != 0 { return 10; }
    if pos_offset(bs) != 0 { return 11; }
    let be: Pos = span_stop(bog);
    if pos_line(be) != 0 { return 12; }
    if span_length(bog) != 0 { return 13; }

    return 0;
}
