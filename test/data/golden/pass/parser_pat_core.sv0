/* parser_pat_core.sv0 — seed for parser/parser.sml
   Transliterates pattern classification logic from parsePat/parsePatAtom.
   Pat tags: PatWild=0, PatBind=1, PatLit=2, PatTuple=3,
   PatPath=4, PatStruct=5, PatOr=6. */

fn pat_kind_from_token(token_tag: i32) -> i32 {
    if token_tag == 95 { return 0; }
    if token_tag == 5 { return 1; }
    if token_tag == 0 { return 2; }
    if token_tag == 1 { return 2; }
    if token_tag == 2 { return 2; }
    if token_tag == 3 { return 2; }
    if token_tag == 4 { return 2; }
    if token_tag == 7 { return 3; }
    return 0 - 1;
}

fn is_pat_start_token(token_tag: i32) -> bool {
    if pat_kind_from_token(token_tag) >= 0 { return true; }
    if token_tag == 5 { return true; }
    return false;
}

fn pat_has_payload(pat_tag: i32) -> bool {
    if pat_tag == 0 { return false; }
    if pat_tag == 1 { return true; }
    if pat_tag == 2 { return true; }
    if pat_tag == 3 { return true; }
    if pat_tag == 4 { return true; }
    if pat_tag == 5 { return true; }
    if pat_tag == 6 { return true; }
    return false;
}

fn pat_binding_count(pat_tag: i32, sub_count: i32) -> i32 {
    if pat_tag == 0 { return 0; }
    if pat_tag == 1 { return 1; }
    if pat_tag == 2 { return 0; }
    if pat_tag == 3 { return sub_count; }
    if pat_tag == 4 { return sub_count; }
    if pat_tag == 5 { return sub_count; }
    if pat_tag == 6 { return sub_count; }
    return 0;
}

fn path_is_enum_ctor(path_len: i32) -> bool {
    return path_len >= 2;
}

fn test_pat_kind() -> i32 {
    if pat_kind_from_token(95) != 0 { return 1; }
    if pat_kind_from_token(5) != 1 { return 2; }
    if pat_kind_from_token(0) != 2 { return 3; }
    if pat_kind_from_token(7) != 3 { return 4; }
    if pat_kind_from_token(99) != 0 - 1 { return 5; }
    return 0;
}

fn test_pat_start() -> i32 {
    if is_pat_start_token(95) != true { return 1; }
    if is_pat_start_token(5) != true { return 2; }
    if is_pat_start_token(0) != true { return 3; }
    if is_pat_start_token(99) != false { return 4; }
    return 0;
}

fn test_pat_payload() -> i32 {
    if pat_has_payload(0) != false { return 1; }
    if pat_has_payload(1) != true { return 2; }
    if pat_has_payload(6) != true { return 3; }
    return 0;
}

fn test_binding_count() -> i32 {
    if pat_binding_count(0, 0) != 0 { return 1; }
    if pat_binding_count(1, 0) != 1 { return 2; }
    if pat_binding_count(3, 3) != 3 { return 3; }
    return 0;
}

fn test_enum_ctor() -> i32 {
    if path_is_enum_ctor(1) != false { return 1; }
    if path_is_enum_ctor(2) != true { return 2; }
    if path_is_enum_ctor(3) != true { return 3; }
    return 0;
}

fn main() -> i32 {
    let r1: i32 = test_pat_kind();
    if r1 != 0 { return 100 + r1; }
    let r2: i32 = test_pat_start();
    if r2 != 0 { return 200 + r2; }
    let r3: i32 = test_pat_payload();
    if r3 != 0 { return 300 + r3; }
    let r4: i32 = test_binding_count();
    if r4 != 0 { return 400 + r4; }
    let r5: i32 = test_enum_ctor();
    if r5 != 0 { return 500 + r5; }
    return 0;
}
