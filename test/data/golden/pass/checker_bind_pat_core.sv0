// Surrogate for checker.sml bindPat: pattern→type binding dispatch.
// SML reference: sml/type_checker/checker.sml (bindPat function)
// Maps pattern kind to the number of new bindings introduced.

fn pat_binding_action(pat_tag: i32) -> i32 {
    if pat_tag == 0 { return 0; }
    if pat_tag == 1 { return 1; }
    if pat_tag == 2 { return 0; }
    if pat_tag == 3 { return 0; }
    if pat_tag == 4 { return 0; }
    if pat_tag == 5 { return 0; }
    if pat_tag == 6 { return 0; }
    return -1;
}

fn pat_introduces_binding(pat_tag: i32) -> bool {
    return pat_tag == 1;
}

fn pat_needs_type_check(pat_tag: i32) -> bool {
    if pat_tag == 2 { return true; }
    if pat_tag == 3 { return true; }
    if pat_tag == 4 { return true; }
    if pat_tag == 5 { return true; }
    return false;
}

fn pat_has_sub_patterns(pat_tag: i32) -> bool {
    if pat_tag == 3 { return true; }
    if pat_tag == 4 { return true; }
    if pat_tag == 5 { return true; }
    if pat_tag == 6 { return true; }
    return false;
}

fn bind_count_in_tuple(p0_bind: bool, p1_bind: bool, p2_bind: bool) -> i32 {
    let mut count: i32 = 0;
    if p0_bind { count = count + 1; }
    if p1_bind { count = count + 1; }
    if p2_bind { count = count + 1; }
    return count;
}

fn enum_pat_scrutinee_check(has_enum: bool, has_variant: bool) -> bool {
    return has_enum && has_variant;
}

fn main() -> i32 {
    if pat_binding_action(0) != 0 { return 1; }
    if pat_binding_action(1) != 1 { return 2; }
    if pat_binding_action(2) != 0 { return 3; }
    if pat_binding_action(99) != -1 { return 4; }

    if !pat_introduces_binding(1) { return 5; }
    if pat_introduces_binding(0) { return 6; }

    if !pat_needs_type_check(2) { return 7; }
    if pat_needs_type_check(0) { return 8; }
    if pat_needs_type_check(1) { return 9; }

    if !pat_has_sub_patterns(3) { return 10; }
    if !pat_has_sub_patterns(6) { return 11; }
    if pat_has_sub_patterns(1) { return 12; }

    if bind_count_in_tuple(true, false, true) != 2 { return 13; }
    if bind_count_in_tuple(true, true, true) != 3 { return 14; }

    if !enum_pat_scrutinee_check(true, true) { return 15; }
    if enum_pat_scrutinee_check(false, true) { return 16; }

    return 0;
}
