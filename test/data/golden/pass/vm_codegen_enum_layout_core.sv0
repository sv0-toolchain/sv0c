// Surrogate for vm_codegen.sml enumLayouts + indexOfField
// Models enum layout width computation: 1 + max variant payload slots.

fn variant_slots(has_payload: bool, payload_fields: i32) -> i32 {
    if !has_payload { return 0; }
    return payload_fields;
}

fn max_variant_slots(s0: i32, s1: i32, s2: i32, s3: i32) -> i32 {
    let mut m: i32 = s0;
    if s1 > m { m = s1; }
    if s2 > m { m = s2; }
    if s3 > m { m = s3; }
    return m;
}

fn enum_layout_width(max_payload: i32) -> i32 {
    return 1 + max_payload;  // tag slot + payload slots
}

fn index_of_field(target: i32, f0: i32, f1: i32, f2: i32, f3: i32) -> i32 {
    if f0 == target { return 0; }
    if f1 == target { return 1; }
    if f2 == target { return 2; }
    if f3 == target { return 3; }
    return -1;  // not found
}

fn enum_field_name_tag(index: i32) -> i32 {
    if index == 0 { return 100; }  // "tag"
    return 200 + index - 1;        // "p0", "p1", ...
}

fn is_enum_item(item_kind: i32) -> bool {
    return item_kind == 3;  // ItemEnum
}

fn main() -> i32 {
    // variant_slots
    if variant_slots(false, 3) != 0 { return 1; }
    if variant_slots(true, 3) != 3 { return 2; }
    if variant_slots(true, 0) != 0 { return 3; }

    // max_variant_slots
    if max_variant_slots(1, 3, 2, 0) != 3 { return 10; }
    if max_variant_slots(0, 0, 0, 0) != 0 { return 11; }
    if max_variant_slots(5, 2, 5, 1) != 5 { return 12; }

    // enum_layout_width: tag + max payload
    if enum_layout_width(0) != 1 { return 20; }
    if enum_layout_width(3) != 4 { return 21; }
    if enum_layout_width(1) != 2 { return 22; }

    // Result: Ok(T) has 1 payload, Err(E) has 1 payload -> width = 1+1 = 2
    let max_r: i32 = max_variant_slots(1, 1, 0, 0);
    if enum_layout_width(max_r) != 2 { return 23; }

    // Option: Some(T) has 1, None has 0 -> width = 1+1 = 2
    let max_o: i32 = max_variant_slots(1, 0, 0, 0);
    if enum_layout_width(max_o) != 2 { return 24; }

    // index_of_field
    if index_of_field(10, 10, 20, 30, 40) != 0 { return 30; }
    if index_of_field(30, 10, 20, 30, 40) != 2 { return 31; }
    if index_of_field(99, 10, 20, 30, 40) != -1 { return 32; }

    // enum_field_name_tag
    if enum_field_name_tag(0) != 100 { return 40; }   // "tag"
    if enum_field_name_tag(1) != 200 { return 41; }   // "p0"
    if enum_field_name_tag(2) != 201 { return 42; }   // "p1"

    // is_enum_item
    if !is_enum_item(3) { return 50; }
    if is_enum_item(1) { return 51; }

    return 0;
}
