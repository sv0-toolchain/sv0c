// Surrogate for lexer.sml scanIdent
// Models identifier scanning: character classification, length counting,
// and the keyword-vs-ident dispatch after scanning.

fn is_ident_start(c: i32) -> bool {
    // a-z
    if c >= 97 && c <= 122 { return true; }
    // A-Z
    if c >= 65 && c <= 90 { return true; }
    // _
    if c == 95 { return true; }
    return false;
}

fn is_ident_cont(c: i32) -> bool {
    if is_ident_start(c) { return true; }
    // 0-9
    if c >= 48 && c <= 57 { return true; }
    return false;
}

fn scan_ident_length(c0: i32, c1: i32, c2: i32, c3: i32, c4: i32) -> i32 {
    if !is_ident_start(c0) { return 0; }
    if !is_ident_cont(c1) { return 1; }
    if !is_ident_cont(c2) { return 2; }
    if !is_ident_cont(c3) { return 3; }
    if !is_ident_cont(c4) { return 4; }
    return 5;
}

fn ident_result_tag(is_keyword: bool) -> i32 {
    if is_keyword { return 1; }
    return 0;
}

fn ident_token_class(first_char: i32) -> i32 {
    // underscore-only idents are wildcards
    if first_char == 95 { return 2; }
    // uppercase start = type-like
    if first_char >= 65 && first_char <= 90 { return 1; }
    // lowercase start = value-like
    return 0;
}

fn main() -> i32 {
    // is_ident_start
    if !is_ident_start(97) { return 1; }   // 'a'
    if !is_ident_start(65) { return 2; }   // 'A'
    if !is_ident_start(95) { return 3; }   // '_'
    if is_ident_start(48) { return 4; }    // '0' is not start
    if is_ident_start(32) { return 5; }    // space is not start

    // is_ident_cont
    if !is_ident_cont(97) { return 10; }   // 'a'
    if !is_ident_cont(48) { return 11; }   // '0' IS cont
    if !is_ident_cont(95) { return 12; }   // '_' IS cont
    if is_ident_cont(32) { return 13; }    // space is not

    // scan_ident_length: "fn" = (102, 110, space, ...)
    let len1: i32 = scan_ident_length(102, 110, 32, 0, 0);
    if len1 != 2 { return 20; }

    // single char: "x" then space
    let len2: i32 = scan_ident_length(120, 32, 0, 0, 0);
    if len2 != 1 { return 21; }

    // not an ident
    let len3: i32 = scan_ident_length(32, 0, 0, 0, 0);
    if len3 != 0 { return 22; }

    // long ident: "abcde"
    let len4: i32 = scan_ident_length(97, 98, 99, 100, 101);
    if len4 != 5 { return 23; }

    // ident_result_tag
    if ident_result_tag(true) != 1 { return 30; }
    if ident_result_tag(false) != 0 { return 31; }

    // ident_token_class
    if ident_token_class(95) != 2 { return 40; }    // _ -> wildcard
    if ident_token_class(65) != 1 { return 41; }    // 'A' -> type
    if ident_token_class(97) != 0 { return 42; }    // 'a' -> value

    return 0;
}
