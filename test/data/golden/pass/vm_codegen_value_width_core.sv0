// Surrogate for vm_codegen.sml valueWidth + lookupSlot: slot width helpers.
// SML reference: sml/backend/vm/vm_codegen.sml (valueWidth, lookupSlot)
// Models how the VM codegen determines how many stack slots a value needs.

fn value_width(val_tag: i32, struct_width: i32, enum_width: i32) -> i32 {
    if val_tag == 0 { return 1; }
    if val_tag == 1 { return 1; }
    if val_tag == 2 { return 1; }
    if val_tag == 3 { return 1; }
    if val_tag == 4 { return struct_width; }
    if val_tag == 5 { return enum_width; }
    if val_tag == 6 { return 1; }
    if val_tag == 7 { return 1; }
    return 1;
}

fn lookup_slot_result(found: bool, slot: i32) -> i32 {
    if found { return slot; }
    return -1;
}

fn slot_search(name: i32, s0_name: i32, s0_slot: i32, s1_name: i32, s1_slot: i32) -> i32 {
    if name == s0_name { return s0_slot; }
    if name == s1_name { return s1_slot; }
    return -1;
}

fn total_slots_for_params(w0: i32, w1: i32, w2: i32) -> i32 {
    return w0 + w1 + w2;
}

fn enc_len_for_value(width: i32) -> i32 {
    return width;
}

fn main() -> i32 {
    if value_width(0, 0, 0) != 1 { return 1; }
    if value_width(4, 3, 0) != 3 { return 2; }
    if value_width(5, 0, 4) != 4 { return 3; }
    if value_width(6, 0, 0) != 1 { return 4; }

    if lookup_slot_result(true, 5) != 5 { return 5; }
    if lookup_slot_result(false, 5) != -1 { return 6; }

    if slot_search(10, 10, 0, 20, 3) != 0 { return 7; }
    if slot_search(20, 10, 0, 20, 3) != 3 { return 8; }
    if slot_search(30, 10, 0, 20, 3) != -1 { return 9; }

    if total_slots_for_params(1, 3, 1) != 5 { return 10; }

    if enc_len_for_value(3) != 3 { return 11; }

    return 0;
}
