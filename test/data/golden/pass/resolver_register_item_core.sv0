/* resolver_register_item_core.sv0 — seed for name_resolution/resolver.sml
   Transliterates variantStem, enumVariantReg, and registerItem
   logic for deriving qualified variant keys and arities. */

fn variant_stem_tag(variant_kind: i32) -> i32 {
    return variant_kind;
}

fn enum_variant_arity(variant_kind: i32, tuple_fields: i32,
                      struct_fields: i32) -> i32 {
    if variant_kind == 0 { return 0; }
    if variant_kind == 1 { return tuple_fields; }
    if variant_kind == 2 { return struct_fields; }
    return 0;
}

fn register_item_tag(item_kind: i32) -> i32 {
    if item_kind == 0 { return 1; }
    if item_kind == 1 { return 2; }
    if item_kind == 2 { return 3; }
    if item_kind == 3 { return 4; }
    if item_kind == 4 { return 5; }
    if item_kind == 5 { return 6; }
    if item_kind == 6 { return 7; }
    if item_kind == 7 { return 8; }
    return 0;
}

fn item_registers_fn(item_kind: i32) -> bool {
    return item_kind == 0;
}

fn item_registers_type(item_kind: i32) -> bool {
    if item_kind == 1 { return true; }
    if item_kind == 2 { return true; }
    if item_kind == 3 { return true; }
    return false;
}

fn item_registers_variants(item_kind: i32) -> bool {
    return item_kind == 2;
}

fn fn_arity_from_params(param_count: i32) -> i32 {
    return param_count;
}

fn variant_count_total(v0_exists: bool, v1_exists: bool,
                       v2_exists: bool, v3_exists: bool) -> i32 {
    let mut count: i32 = 0;
    if v0_exists { count = count + 1; }
    if v1_exists { count = count + 1; }
    if v2_exists { count = count + 1; }
    if v3_exists { count = count + 1; }
    return count;
}

fn test_variant_arity() -> i32 {
    if enum_variant_arity(0, 0, 0) != 0 { return 1; }
    if enum_variant_arity(1, 3, 0) != 3 { return 2; }
    if enum_variant_arity(2, 0, 5) != 5 { return 3; }
    return 0;
}

fn test_register_item() -> i32 {
    if register_item_tag(0) != 1 { return 1; }
    if register_item_tag(2) != 3 { return 2; }
    if register_item_tag(7) != 8 { return 3; }
    if register_item_tag(8) != 0 { return 4; }
    return 0;
}

fn test_item_predicates() -> i32 {
    if item_registers_fn(0) != true { return 1; }
    if item_registers_fn(1) != false { return 2; }
    if item_registers_type(1) != true { return 3; }
    if item_registers_type(2) != true { return 4; }
    if item_registers_type(0) != false { return 5; }
    if item_registers_variants(2) != true { return 6; }
    if item_registers_variants(1) != false { return 7; }
    return 0;
}

fn test_variant_count() -> i32 {
    if variant_count_total(true, true, false, false) != 2 { return 1; }
    if variant_count_total(true, true, true, true) != 4 { return 2; }
    if variant_count_total(false, false, false, false) != 0 { return 3; }
    return 0;
}

fn main() -> i32 {
    let r1: i32 = test_variant_arity();
    if r1 != 0 { return 100 + r1; }
    let r2: i32 = test_register_item();
    if r2 != 0 { return 200 + r2; }
    let r3: i32 = test_item_predicates();
    if r3 != 0 { return 300 + r3; }
    let r4: i32 = test_variant_count();
    if r4 != 0 { return 400 + r4; }
    return 0;
}
