/* vm_codegen_variant_slots_core.sv0 — seed for backend/vm/vm_codegen.sml
   Transliterates variantSlots (payload count per variant) and
   enumLayouts (1 + max slots across variants). */

fn variant_slots(kind: i32, tuple_fields: i32, struct_fields: i32) -> i32 {
    if kind == 0 { return 0; }
    if kind == 1 { return tuple_fields; }
    if kind == 2 { return struct_fields; }
    return 0;
}

fn max2(a: i32, b: i32) -> i32 {
    if a > b { return a; }
    return b;
}

fn max3(a: i32, b: i32, c: i32) -> i32 {
    return max2(max2(a, b), c);
}

fn enum_layout_width(v0_kind: i32, v0_tup: i32, v0_str: i32,
                     v1_kind: i32, v1_tup: i32, v1_str: i32,
                     v2_kind: i32, v2_tup: i32, v2_str: i32) -> i32 {
    let s0: i32 = variant_slots(v0_kind, v0_tup, v0_str);
    let s1: i32 = variant_slots(v1_kind, v1_tup, v1_str);
    let s2: i32 = variant_slots(v2_kind, v2_tup, v2_str);
    return 1 + max3(s0, s1, s2);
}

fn struct_layout_width(field_count: i32) -> i32 {
    return field_count;
}

fn enum_field_names_count(enum_width: i32) -> i32 {
    return enum_width;
}

fn test_variant_slots() -> i32 {
    if variant_slots(0, 0, 0) != 0 { return 1; }
    if variant_slots(1, 3, 0) != 3 { return 2; }
    if variant_slots(2, 0, 5) != 5 { return 3; }
    if variant_slots(1, 1, 0) != 1 { return 4; }
    return 0;
}

fn test_enum_layout() -> i32 {
    let w1: i32 = enum_layout_width(0, 0, 0, 1, 2, 0, 1, 3, 0);
    if w1 != 4 { return 1; }
    let w2: i32 = enum_layout_width(0, 0, 0, 0, 0, 0, 0, 0, 0);
    if w2 != 1 { return 2; }
    let w3: i32 = enum_layout_width(2, 0, 4, 1, 2, 0, 0, 0, 0);
    if w3 != 5 { return 3; }
    let w4: i32 = enum_layout_width(1, 1, 0, 1, 1, 0, 1, 1, 0);
    if w4 != 2 { return 4; }
    return 0;
}

fn test_struct_layout() -> i32 {
    if struct_layout_width(0) != 0 { return 1; }
    if struct_layout_width(3) != 3 { return 2; }
    if struct_layout_width(7) != 7 { return 3; }
    return 0;
}

fn main() -> i32 {
    let r1: i32 = test_variant_slots();
    if r1 != 0 { return 100 + r1; }
    let r2: i32 = test_enum_layout();
    if r2 != 0 { return 200 + r2; }
    let r3: i32 = test_struct_layout();
    if r3 != 0 { return 300 + r3; }
    return 0;
}
