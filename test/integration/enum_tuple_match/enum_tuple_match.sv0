enum Msg {
  Empty(),
  Num(i32),
  Pair(i32, i32),
}

fn classify(m: Msg) -> i32 {
  return match m {
    Msg::Empty() => 0,
    Msg::Num(x) => x,
    Msg::Pair(a, b) => a + b,
  };
}

fn main() -> i32 {
  let e = classify(Msg::Empty());
  let n = classify(Msg::Num(10));
  let p = classify(Msg::Pair(20, 22));
  if e == 0 {
    if n == 10 {
      if p == 42 {
        return 0;
      };
    };
  };
  return 1;
}
