fn main() -> i32 {
    let s: string = "hello";
    let t: string = "world";

    let len: i32 = string_len(s);
    if len != 5 {
        return 1;
    }

    let eq1: bool = string_eq(s, s);
    if !eq1 {
        return 2;
    }
    let eq2: bool = string_eq(s, t);
    if eq2 {
        return 3;
    }

    let cat: string = string_concat(s, t);
    let cat_len: i32 = string_len(cat);
    if cat_len != 10 {
        return 4;
    }

    let ch: i32 = string_char_at(s, 1);
    if ch != 101 {
        return 5;
    }

    let sub: string = string_substr(s, 1, 3);
    let sub_eq: bool = string_eq(sub, "ell");
    if !sub_eq {
        return 6;
    }

    return 0;
}
