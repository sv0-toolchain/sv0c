fn main() -> i32 {
  let v: Vec<i32> = vec_new();
  vec_push(v, 10);
  vec_push(v, 20);
  vec_push(v, 30);

  let n: i32 = vec_len(v);
  if n != 3 { return 1; };

  let x: i32 = vec_get(v, 0);
  if x != 10 { return 2; };
  let y: i32 = vec_get(v, 1);
  if y != 20 { return 3; };
  let z: i32 = vec_get(v, 2);
  if z != 30 { return 4; };

  vec_set(v, 1, 99);
  let w: i32 = vec_get(v, 1);
  if w != 99 { return 5; };

  let mut sum: i32 = 0;
  for i in 0..vec_len(v) {
    sum = sum + vec_get(v, i);
  };
  if sum != 139 { return 6; };

  return 0;
}
