enum Shape {
    Circle(i32),
    Rect { w: i32, h: i32 },
    Point,
}

fn area(s: Shape) -> i32 {
    match s {
        Shape::Circle(r) => r * r,
        Shape::Rect { w, h } => w * h,
        Shape::Point => 0,
    }
}

fn main() -> i32 {
    let c: Shape = Shape::Circle(5);
    let r: Shape = Shape::Rect(3, 4);
    let p: Shape = Shape::Point;
    let a1: i32 = area(c);
    let a2: i32 = area(r);
    let a3: i32 = area(p);
    if a1 != 25 {
        return 1;
    }
    if a2 != 12 {
        return 2;
    }
    if a3 != 0 {
        return 3;
    }
    return 0;
}
