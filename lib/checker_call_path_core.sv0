        return 524;
    }
    // println: exactly 1 arg
    if path_tag == 4 {
        if arg_count == 1 { return 0; }
        return 444;
    }
    return 0;
}

// user fn arity: compare arg_count vs param_count (E0413)
fn fn_arity_check(arg_count: i32, param_count: i32) -> i32 {
    if arg_count == param_count {
        return 0;
