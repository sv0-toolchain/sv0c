fn call_path_tag(seg_count: i32, first_seg_id: i32) -> i32 {
    if seg_count == 1 {
        if first_seg_id == 0 { return 0; }
        if first_seg_id == 1 { return 1; }
        if first_seg_id == 2 { return 2; }
        if first_seg_id == 3 { return 3; }
        if first_seg_id == 4 { return 4; }
        return 5;
    }
    if seg_count >= 2 {
        return 6;
    }
    return 255;
}

