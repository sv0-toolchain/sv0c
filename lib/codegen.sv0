/* Phase 2 real pipeline module: sml/backend/c/codegen.sml -> sv0.
   C99 code emission from flat IR values, expressions, and instructions.
   Covers the full codegen.sml surface: emitValue, emitExpr,
   cEscapeString, intToString, emitCallArgs, emitInstr (16 kinds
   including IfElse/While/Block with recursive Vec<i32> + Box<Instr>
   iteration and Call with Vec<i32> + Box<Value> arguments),
   emitParamList (general over Vec<Param>), emitFnProto,
   emitBlockBody, emitBlockDefn, splitMain, emit (top-level). */

enum Value {
    VInt(i32),
    VBoolTrue,
    VBoolFalse,
    VVar(i32),
    VUnit,
    VString(i32),
    VMember(Box<Value>, i32),
    VAddrOf(i32),
}

enum Expr {
    Literal(Box<Value>),
    Load(i32),
    Binop(i32, Box<Value>, Box<Value>),
    Unop(i32, Box<Value>),
    FieldAccess(Box<Value>, i32),
}

fn value_tag(v: Value) -> i32 {
    match v {
        Value::VInt(_) => { return 0; },
        Value::VBoolTrue => { return 1; },
        Value::VBoolFalse => { return 2; },
        Value::VVar(_) => { return 3; },
        Value::VUnit => { return 4; },
        Value::VString(_) => { return 5; },
        Value::VMember(_, _) => { return 6; },
        Value::VAddrOf(_) => { return 7; },
    }
}

fn expr_tag(e: Expr) -> i32 {
    match e {
        Expr::Literal(_) => { return 0; },
        Expr::Load(_) => { return 1; },
        Expr::Binop(_, _, _) => { return 2; },
        Expr::Unop(_, _) => { return 3; },
        Expr::FieldAccess(_, _) => { return 4; },
    }
}

fn name_of(h: i32) -> string {
    if h == 1 { return "x"; }
    if h == 2 { return "y"; }
    if h == 3 { return "n"; }
    if h == 4 { return "tmp"; }
    if h == 5 { return "count"; }
    if h == 6 { return "val"; }
    if h == 7 { return "hello"; }
    if h == 8 { return "data"; }
    if h == 9 { return "int"; }
    if h == 10 { return "void"; }
    if h == 11 { return "main"; }
    if h == 12 { return "foo"; }
    if h == 13 { return "bar"; }
    if h == 14 { return "result"; }
    if h == 15 { return "i"; }
    return "?";
}

fn op_of(h: i32) -> string {
    if h == 1 { return "+"; }
    if h == 2 { return "-"; }
    if h == 3 { return "*"; }
    if h == 4 { return "=="; }
    if h == 5 { return "!="; }
    if h == 6 { return "!"; }
    if h == 7 { return "<"; }
    if h == 8 { return "&&"; }
    return "?";
}

fn digit_char(d: i32) -> string {
    if d == 0 { return "0"; }
    if d == 1 { return "1"; }
    if d == 2 { return "2"; }
    if d == 3 { return "3"; }
    if d == 4 { return "4"; }
    if d == 5 { return "5"; }
    if d == 6 { return "6"; }
    if d == 7 { return "7"; }
    if d == 8 { return "8"; }
    if d == 9 { return "9"; }
    return "?";
}

fn int_to_str_pos(n: i32) -> string {
    if n < 10 { return digit_char(n); }
    let rest: i32 = n / 10;
    let d: i32 = n % 10;
    return string_concat(int_to_str_pos(rest), digit_char(d));
}

fn int_to_string(n: i32) -> string {
    if n == 0 { return "0"; }
    if n < 0 { return string_concat("-", int_to_str_pos(0 - n)); }
    return int_to_str_pos(n);
}

fn c_escape_one(c: i32, src: string, pos: i32) -> string {
    if c == 34 { return "\\\""; }
    if c == 92 { return "\\\\"; }
    if c == 10 { return "\\n"; }
    if c == 9 { return "\\t"; }
    if c == 13 { return "\\r"; }
    return string_substr(src, pos, 1);
}

fn c_escape_from(src: string, pos: i32, acc: string) -> string {
    if pos >= string_len(src) { return acc; }
    let c: i32 = string_char_at(src, pos);
    let esc: string = c_escape_one(c, src, pos);
    return c_escape_from(src, pos + 1, string_concat(acc, esc));
}

fn c_escape_string(s: string) -> string {
    return c_escape_from(s, 0, "");
}

fn emit_value(v: Value) -> string {
    match v {
        Value::VInt(i) => { return int_to_string(i); },
        Value::VBoolTrue => { return "1"; },
        Value::VBoolFalse => { return "0"; },
        Value::VVar(h) => { return name_of(h); },
        Value::VUnit => { return "0"; },
        Value::VString(h) => {
            let raw: string = name_of(h);
            let escaped: string = c_escape_string(raw);
            let a: string = string_concat("\"", escaped);
            return string_concat(a, "\"");
        },
        Value::VMember(bv, fh) => {
            let inner: Value = box_deref(bv);
            let field: string = name_of(fh);
            let tag: i32 = value_tag(inner);
            if tag == 3 {
                let prefix: string = emit_value(inner);
                return string_concat(string_concat(prefix, "."), field);
            }
            let prefix: string = string_concat("(", emit_value(inner));
            return string_concat(string_concat(prefix, ")."), field);
        },
        Value::VAddrOf(h) => {
            return string_concat(string_concat("(&", name_of(h)), ")");
        },
    }
    return "";
}

fn emit_expr(e: Expr) -> string {
    match e {
        Expr::Literal(bv) => {
            let v: Value = box_deref(bv);
            return emit_value(v);
        },
        Expr::Load(h) => {
            return name_of(h);
        },
        Expr::Binop(op_h, bv1, bv2) => {
            let v1: Value = box_deref(bv1);
            let v2: Value = box_deref(bv2);
            let s1: string = emit_value(v1);
            let s2: string = emit_value(v2);
            let op: string = op_of(op_h);
            let a: string = string_concat("(", s1);
            let b: string = string_concat(a, " ");
            let c: string = string_concat(b, op);
            let d: string = string_concat(c, " ");
            let f: string = string_concat(d, s2);
            return string_concat(f, ")");
        },
        Expr::Unop(op_h, bv) => {
            let v: Value = box_deref(bv);
            let op: string = op_of(op_h);
            let inner: string = emit_value(v);
            let a: string = string_concat("(", op);
            return string_concat(a, string_concat(inner, ")"));
        },
        Expr::FieldAccess(bv, fh) => {
            let v: Value = box_deref(bv);
            let a: string = string_concat("(", emit_value(v));
            return string_concat(string_concat(a, ")."), name_of(fh));
        },
    }
    return "";
}

enum Instr {
    Nop,
    DeclVar(i32),
    DeclNamed(i32, i32),
    Assign(i32, Box<Expr>),
    Store(i32, Box<Expr>),
    StoreField(i32, i32, Box<Expr>),
    IfElse(Box<Expr>, Vec<i32>, Vec<i32>),
    WhileLoop(Box<Expr>, Vec<i32>),
    BlockInstr(Vec<i32>),
    Break,
    Continue,
    Call(i32, i32, Vec<i32>, i32),
    Requires(Box<Expr>, i32),
    Ensures(Box<Expr>, i32),
    ReturnVoid,
    ReturnVal(Box<Value>),
}

fn instr_tag(ins: Instr) -> i32 {
    match ins {
        Instr::Nop => { return 0; },
        Instr::DeclVar(h) => { return 1; },
        Instr::DeclNamed(ct, h) => { return 2; },
        Instr::Assign(h, be) => { return 3; },
        Instr::Store(h, be) => { return 4; },
        Instr::StoreField(b, f, be) => { return 5; },
        Instr::IfElse(be, th, el) => { return 6; },
        Instr::WhileLoop(be, body) => { return 7; },
        Instr::BlockInstr(body) => { return 8; },
        Instr::Break => { return 9; },
        Instr::Continue => { return 10; },
        Instr::Call(dh, fh, args, rh) => { return 11; },
        Instr::Requires(be, fh) => { return 12; },
        Instr::Ensures(be, fh) => { return 13; },
        Instr::ReturnVoid => { return 14; },
        Instr::ReturnVal(bv) => { return 15; },
    }
}

fn emit_call_args(args: Vec<i32>) -> string {
    let count: i32 = vec_len(args);
    if count == 0 { return ""; }
    let mut out: string = "";
    let mut idx: i32 = 0;
    while idx < count {
        if idx > 0 {
            out = string_concat(out, ", ");
        }
        let bv: Box<Value> = vec_get(args, idx);
        let v: Value = box_deref(bv);
        out = string_concat(out, emit_value(v));
        idx = idx + 1;
    }
    return out;
}

fn emit_call_void(indent: string, fn_h: i32, args: Vec<i32>) -> string {
    let arg_str: string = emit_call_args(args);
    let a: string = string_concat(indent, name_of(fn_h));
    let b: string = string_concat(a, "(");
    let c: string = string_concat(b, arg_str);
    return string_concat(c, ");\n");
}

fn emit_call_dest(indent: string, dst_h: i32, fn_h: i32, args: Vec<i32>, rt_h: i32) -> string {
    let arg_str: string = emit_call_args(args);
    let fn_name: string = name_of(fn_h);
    let ret_name: string = name_of(rt_h);
    let a: string = string_concat(indent, ret_name);
    let b: string = string_concat(a, " ");
    let c: string = string_concat(b, name_of(dst_h));
    let d: string = string_concat(c, " = ");
    let e: string = string_concat(d, fn_name);
    let f: string = string_concat(e, "(");
    let g: string = string_concat(f, arg_str);
    return string_concat(g, ");\n");
}

fn emit_instr(indent: string, ret_ty: string, ins: Instr) -> string {
    match ins {
        Instr::Nop => { return ""; },
        Instr::DeclVar(h) => {
            let a: string = string_concat(indent, "int ");
            let b: string = string_concat(a, name_of(h));
            return string_concat(b, ";\n");
        },
        Instr::DeclNamed(ct, h) => {
            let a: string = string_concat(indent, name_of(ct));
            let b: string = string_concat(a, " ");
            let c: string = string_concat(b, name_of(h));
            return string_concat(c, ";\n");
        },
        Instr::Assign(h, be) => {
            let e: Expr = box_deref(be);
            let a: string = string_concat(indent, "int ");
            let b: string = string_concat(a, name_of(h));
            let c: string = string_concat(b, " = ");
            let d: string = string_concat(c, emit_expr(e));
            return string_concat(d, ";\n");
        },
        Instr::Store(h, be) => {
            let e: Expr = box_deref(be);
            let a: string = string_concat(indent, name_of(h));
            let b: string = string_concat(a, " = ");
            let c: string = string_concat(b, emit_expr(e));
            return string_concat(c, ";\n");
        },
        Instr::StoreField(bh, fh, be) => {
            let e: Expr = box_deref(be);
            let a: string = string_concat(indent, name_of(bh));
            let b: string = string_concat(a, ".");
            let c: string = string_concat(b, name_of(fh));
            let d: string = string_concat(c, " = ");
            let f: string = string_concat(d, emit_expr(e));
            return string_concat(f, ";\n");
        },
        Instr::IfElse(be, th, el) => {
            let e: Expr = box_deref(be);
            let deeper: string = string_concat(indent, "  ");
            let a: string = string_concat(indent, "if (");
            let b: string = string_concat(a, emit_expr(e));
            let c: string = string_concat(b, ") {\n");
            let d: string = string_concat(c, emit_instrs(th, deeper, ret_ty));
            let f: string = string_concat(d, indent);
            let g: string = string_concat(f, "} else {\n");
            let h: string = string_concat(g, emit_instrs(el, deeper, ret_ty));
            let j: string = string_concat(h, indent);
            return string_concat(j, "}\n");
        },
        Instr::WhileLoop(be, body) => {
            let e: Expr = box_deref(be);
            let deeper: string = string_concat(indent, "  ");
            let a: string = string_concat(indent, "while (");
            let b: string = string_concat(a, emit_expr(e));
            let c: string = string_concat(b, ") {\n");
            let d: string = string_concat(c, emit_instrs(body, deeper, ret_ty));
            let f: string = string_concat(d, indent);
            return string_concat(f, "}\n");
        },
        Instr::BlockInstr(body) => {
            let deeper: string = string_concat(indent, "  ");
            let a: string = string_concat(indent, "{\n");
            let b: string = string_concat(a, emit_instrs(body, deeper, ret_ty));
            let c: string = string_concat(b, indent);
            return string_concat(c, "}\n");
        },
        Instr::Break => {
            return string_concat(indent, "break;\n");
        },
        Instr::Continue => {
            return string_concat(indent, "continue;\n");
        },
        Instr::Call(dst_h, fn_h, args, rt_h) => {
            if dst_h == 0 {
                return emit_call_void(indent, fn_h, args);
            }
            return emit_call_dest(indent, dst_h, fn_h, args, rt_h);
        },
        Instr::Requires(be, fh) => {
            let e: Expr = box_deref(be);
            let a: string = string_concat(indent, "sv0_requires(");
            let b: string = string_concat(a, emit_expr(e));
            let c: string = string_concat(b, ", \"");
            let d: string = string_concat(c, name_of(fh));
            return string_concat(d, "\");\n");
        },
        Instr::Ensures(be, fh) => {
            let e: Expr = box_deref(be);
            let a: string = string_concat(indent, "sv0_ensures(");
            let b: string = string_concat(a, emit_expr(e));
            let c: string = string_concat(b, ", \"");
            let d: string = string_concat(c, name_of(fh));
            return string_concat(d, "\");\n");
        },
        Instr::ReturnVoid => {
            return string_concat(indent, "return;\n");
        },
        Instr::ReturnVal(bv) => {
            if string_eq(ret_ty, "void") {
                return string_concat(indent, "return;\n");
            }
            let v: Value = box_deref(bv);
            let a: string = string_concat(indent, "return ");
            let b: string = string_concat(a, emit_value(v));
            return string_concat(b, ";\n");
        },
    }
    return "";
}

fn emit_instrs(instrs: Vec<i32>, indent: string, ret_ty: string) -> string {
    let count: i32 = vec_len(instrs);
    if count == 0 { return ""; }
    let mut out: string = "";
    let mut idx: i32 = 0;
    while idx < count {
        let bh: Box<Instr> = vec_get(instrs, idx);
        let ins: Instr = box_deref(bh);
        out = string_concat(out, emit_instr(indent, ret_ty, ins));
        idx = idx + 1;
    }
    return out;
}

fn emit_param_pair(cty_h: i32, name_h: i32) -> string {
    let a: string = string_concat(name_of(cty_h), " ");
    return string_concat(a, name_of(name_h));
}

fn emit_param_list_0() -> string {
    return "void";
}

fn emit_param_list_1(cty1: i32, n1: i32) -> string {
    return emit_param_pair(cty1, n1);
}

fn emit_param_list_2(cty1: i32, n1: i32, cty2: i32, n2: i32) -> string {
    let a: string = emit_param_pair(cty1, n1);
    let b: string = string_concat(a, ", ");
    return string_concat(b, emit_param_pair(cty2, n2));
}

fn emit_fn_proto(is_static: i32, ret_cty_h: i32, label_h: i32, params_str: string) -> string {
    let ret: string = name_of(ret_cty_h);
    let label: string = name_of(label_h);
    if is_static == 1 {
        let a: string = string_concat("static ", ret);
        let b: string = string_concat(a, " ");
        let c: string = string_concat(b, label);
        let d: string = string_concat(c, "(");
        return string_concat(d, string_concat(params_str, ")"));
    }
    let a: string = string_concat(ret, " ");
    let b: string = string_concat(a, label);
    let c: string = string_concat(b, "(");
    return string_concat(c, string_concat(params_str, ")"));
}

fn emit_block_defn(proto: string, body: string) -> string {
    let a: string = string_concat(proto, " {\n");
    let b: string = string_concat(a, body);
    return string_concat(b, "}\n\n");
}

/* emit_param_list takes a Vec<i32> of interleaved pairs:
   [ctype_h, name_h, ctype_h, name_h, ...].
   Param count = vec_len / 2. Structs cannot be boxed in sv0, so we
   store params as flat i32 pairs rather than Box<Param>. */
fn emit_param_list(params: Vec<i32>) -> string {
    let total: i32 = vec_len(params);
    if total == 0 { return "void"; }
    let count: i32 = total / 2;
    let mut out: string = "";
    let mut idx: i32 = 0;
    while idx < count {
        if idx > 0 {
            out = string_concat(out, ", ");
        }
        let ct_h: i32 = vec_get(params, idx * 2);
        let nm_h: i32 = vec_get(params, idx * 2 + 1);
        let pair: string = string_concat(name_of(ct_h), " ");
        out = string_concat(out, string_concat(pair, name_of(nm_h)));
        idx = idx + 1;
    }
    return out;
}

fn emit_fn_proto_ex(is_static: i32, ret_cty_h: i32, label_h: i32, params: Vec<i32>) -> string {
    let ret: string = name_of(ret_cty_h);
    let label: string = name_of(label_h);
    let pstr: string = emit_param_list(params);
    if is_static == 1 {
        let a: string = string_concat("static ", ret);
        let b: string = string_concat(a, " ");
        let c: string = string_concat(b, label);
        let d: string = string_concat(c, "(");
        return string_concat(d, string_concat(pstr, ")"));
    }
    let a: string = string_concat(ret, " ");
    let b: string = string_concat(a, label);
    let c: string = string_concat(b, "(");
    return string_concat(c, string_concat(pstr, ")"));
}

/* emit_program: top-level C file generation from a flat IR program.
   blocks is a Vec<i32> in 4-stride layout:
     blocks[i*4]   = label name handle
     blocks[i*4+1] = return C type name handle
     blocks[i*4+2] = params Vec handle (interleaved ctype_h, name_h pairs)
     blocks[i*4+3] = instrs Vec handle (Box<Instr> handles)
   Block count = vec_len(blocks) / 4.
   Label handle 11 ("main") is emitted non-static; all others are
   static with forward declarations, mirroring codegen.sml's emit. */
fn emit_program(typedefs: string, blocks: Vec<i32>) -> string {
    let num_blocks: i32 = vec_len(blocks) / 4;
    if num_blocks == 0 {
        return "#include \"sv0_runtime.h\"\nint main(void) { return 0; }\n";
    }
    let prelude: string = "#include \"sv0_runtime.h\"\n\n";
    let mut td_part: string = "";
    if !string_eq(typedefs, "") {
        td_part = string_concat(typedefs, "\n");
    }
    let mut fwd_decls: string = "";
    let mut statics: string = "";
    let mut main_part: string = "";
    let mut idx: i32 = 0;
    while idx < num_blocks {
        let label_h: i32 = vec_get(blocks, idx * 4);
        let ret_h: i32 = vec_get(blocks, idx * 4 + 1);
        let params: Vec<i32> = vec_get(blocks, idx * 4 + 2);
        let instrs: Vec<i32> = vec_get(blocks, idx * 4 + 3);
        let ret_name: string = name_of(ret_h);
        if label_h == 11 {
            let proto: string = emit_fn_proto_ex(0, ret_h, label_h, params);
            let body: string = emit_instrs(instrs, "  ", ret_name);
            main_part = emit_block_defn(proto, body);
        } else {
            let proto: string = emit_fn_proto_ex(1, ret_h, label_h, params);
            fwd_decls = string_concat(fwd_decls, string_concat(proto, ";\n"));
            let body: string = emit_instrs(instrs, "  ", ret_name);
            statics = string_concat(statics, emit_block_defn(proto, body));
        }
        idx = idx + 1;
    }
    if string_eq(main_part, "") {
        main_part = "int main(void) { return 0; }\n";
    }
    let mut out: string = string_concat(prelude, td_part);
    out = string_concat(out, fwd_decls);
    out = string_concat(out, "\n");
    out = string_concat(out, statics);
    return string_concat(out, main_part);
}

fn test_int_format() -> i32 {
    if !string_eq(int_to_string(0), "0") { return 1; }
    if !string_eq(int_to_string(1), "1") { return 2; }
    if !string_eq(int_to_string(42), "42") { return 3; }
    if !string_eq(int_to_string(100), "100") { return 4; }
    if !string_eq(int_to_string(9999), "9999") { return 5; }
    if !string_eq(int_to_string(-1), "-1") { return 6; }
    if !string_eq(int_to_string(-42), "-42") { return 7; }
    return 0;
}

fn test_escape() -> i32 {
    if !string_eq(c_escape_string("hello"), "hello") { return 1; }
    if !string_eq(c_escape_string(""), "") { return 2; }
    if !string_eq(c_escape_string("ab"), "ab") { return 3; }
    return 0;
}

fn test_emit_value_basic() -> i32 {
    let v1: Value = Value::VInt(42);
    if !string_eq(emit_value(v1), "42") { return 1; }
    let v2: Value = Value::VBoolTrue;
    if !string_eq(emit_value(v2), "1") { return 2; }
    let v3: Value = Value::VBoolFalse;
    if !string_eq(emit_value(v3), "0") { return 3; }
    let v4: Value = Value::VVar(1);
    if !string_eq(emit_value(v4), "x") { return 4; }
    let v5: Value = Value::VUnit;
    if !string_eq(emit_value(v5), "0") { return 5; }
    return 0;
}

fn test_emit_value_string() -> i32 {
    let v: Value = Value::VString(7);
    let s: string = emit_value(v);
    if !string_eq(s, "\"hello\"") { return 1; }
    return 0;
}

fn test_emit_value_addr() -> i32 {
    let v: Value = Value::VAddrOf(1);
    if !string_eq(emit_value(v), "(&x)") { return 1; }
    return 0;
}

fn test_emit_member() -> i32 {
    let inner: Value = Value::VVar(1);
    let bv: Box<Value> = box_new(inner);
    let v: Value = Value::VMember(bv, 2);
    if !string_eq(emit_value(v), "x.y") { return 1; }
    return 0;
}

fn test_emit_expr_lit() -> i32 {
    let v: Value = Value::VInt(7);
    let bv: Box<Value> = box_new(v);
    let e: Expr = Expr::Literal(bv);
    if !string_eq(emit_expr(e), "7") { return 1; }
    return 0;
}

fn test_emit_expr_load() -> i32 {
    let e: Expr = Expr::Load(1);
    if !string_eq(emit_expr(e), "x") { return 1; }
    return 0;
}

fn test_emit_expr_binop() -> i32 {
    let v1: Value = Value::VVar(1);
    let v2: Value = Value::VVar(2);
    let bv1: Box<Value> = box_new(v1);
    let bv2: Box<Value> = box_new(v2);
    let e: Expr = Expr::Binop(1, bv1, bv2);
    if !string_eq(emit_expr(e), "(x + y)") { return 1; }
    return 0;
}

