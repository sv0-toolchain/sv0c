fn test_instr_nop() -> i32 {
    let ins: Instr = Instr::Nop;
    if instr_tag(ins) != 0 { return 1; }
    let s: string = emit_instr("  ", "int", ins);
    if !string_eq(s, "") { return 2; }
    return 0;
}

