fn test_param_list() -> i32 {
    if !string_eq(emit_param_list_0(), "void") { return 1; }
    if !string_eq(emit_param_list_1(9, 1), "int x") { return 2; }
    if !string_eq(emit_param_list_2(9, 1, 9, 2), "int x, int y") { return 3; }
    return 0;
}

fn test_fn_proto() -> i32 {
    let s1: string = emit_fn_proto(1, 9, 12, "void");
    if !string_eq(s1, "static int foo(void)") { return 1; }
    let s2: string = emit_fn_proto(0, 9, 11, "int x, int y");
    if !string_eq(s2, "int main(int x, int y)") { return 2; }
    let s3: string = emit_fn_proto(1, 10, 13, "int n");
    if !string_eq(s3, "static void bar(int n)") { return 3; }
    return 0;
}

fn test_param_list_general() -> i32 {
    let mut p0: Vec<i32> = vec_new();
    if !string_eq(emit_param_list(p0), "void") { return 1; }
    let mut p1: Vec<i32> = vec_new();
    vec_push(p1, 9);
    vec_push(p1, 1);
    if !string_eq(emit_param_list(p1), "int x") { return 2; }
    let mut p2: Vec<i32> = vec_new();
    vec_push(p2, 9);
    vec_push(p2, 1);
    vec_push(p2, 9);
    vec_push(p2, 2);
    if !string_eq(emit_param_list(p2), "int x, int y") { return 3; }
    let mut p3: Vec<i32> = vec_new();
    vec_push(p3, 9);
    vec_push(p3, 1);
    vec_push(p3, 10);
    vec_push(p3, 2);
    vec_push(p3, 9);
    vec_push(p3, 3);
    if !string_eq(emit_param_list(p3), "int x, void y, int n") { return 4; }
    return 0;
}

fn test_emit_program_empty() -> i32 {
    let mut blocks: Vec<i32> = vec_new();
    let s: string = emit_program("", blocks);
    let expected: string = "#include \"sv0_runtime.h\"\nint main(void) { return 0; }\n";
    if !string_eq(s, expected) { return 1; }
    return 0;
}

fn test_emit_program_main_only() -> i32 {
    let mut blocks: Vec<i32> = vec_new();
    let mut params: Vec<i32> = vec_new();
    let mut instrs: Vec<i32> = vec_new();
    vec_push(instrs, box_new(Instr::ReturnVal(box_new(Value::VInt(0)))));
    vec_push(blocks, 11);
    vec_push(blocks, 9);
    vec_push(blocks, params);
    vec_push(blocks, instrs);
    let s: string = emit_program("", blocks);
    let expected: string = "#include \"sv0_runtime.h\"\n\n\nint main(void) {\n  return 0;\n}\n\n";
    if !string_eq(s, expected) { return 1; }
    return 0;
}

fn test_emit_program_with_helper() -> i32 {
    let mut blocks: Vec<i32> = vec_new();
    let mut foo_params: Vec<i32> = vec_new();
    vec_push(foo_params, 9);
    vec_push(foo_params, 3);
    let mut foo_instrs: Vec<i32> = vec_new();
    vec_push(foo_instrs, box_new(Instr::ReturnVal(box_new(Value::VVar(3)))));
    vec_push(blocks, 12);
    vec_push(blocks, 9);
    vec_push(blocks, foo_params);
    vec_push(blocks, foo_instrs);
    let mut main_params: Vec<i32> = vec_new();
    let mut main_instrs: Vec<i32> = vec_new();
    vec_push(main_instrs, box_new(Instr::ReturnVal(box_new(Value::VInt(0)))));
    vec_push(blocks, 11);
    vec_push(blocks, 9);
    vec_push(blocks, main_params);
    vec_push(blocks, main_instrs);
    let s: string = emit_program("", blocks);
    let mut exp: string = "#include \"sv0_runtime.h\"\n\n";
    exp = string_concat(exp, "static int foo(int n);\n");
    exp = string_concat(exp, "\n");
    exp = string_concat(exp, "static int foo(int n) {\n  return n;\n}\n\n");
    exp = string_concat(exp, "int main(void) {\n  return 0;\n}\n\n");
    if !string_eq(s, exp) { return 1; }
    return 0;
}

fn test_emit_program_typedefs() -> i32 {
    let mut blocks: Vec<i32> = vec_new();
    let mut params: Vec<i32> = vec_new();
    let mut instrs: Vec<i32> = vec_new();
    vec_push(instrs, box_new(Instr::ReturnVal(box_new(Value::VInt(0)))));
    vec_push(blocks, 11);
    vec_push(blocks, 9);
    vec_push(blocks, params);
    vec_push(blocks, instrs);
    let s: string = emit_program("typedef int sv0_int;", blocks);
    let mut exp: string = "#include \"sv0_runtime.h\"\n\n";
    exp = string_concat(exp, "typedef int sv0_int;\n");
    exp = string_concat(exp, "\n");
    exp = string_concat(exp, "int main(void) {\n  return 0;\n}\n\n");
    if !string_eq(s, exp) { return 1; }
    return 0;
}

fn test_emit_program_no_main() -> i32 {
    let mut blocks: Vec<i32> = vec_new();
    let mut foo_params: Vec<i32> = vec_new();
    let mut foo_instrs: Vec<i32> = vec_new();
    vec_push(foo_instrs, box_new(Instr::ReturnVal(box_new(Value::VInt(1)))));
    vec_push(blocks, 12);
    vec_push(blocks, 9);
    vec_push(blocks, foo_params);
    vec_push(blocks, foo_instrs);
    let s: string = emit_program("", blocks);
    let mut exp: string = "#include \"sv0_runtime.h\"\n\n";
    exp = string_concat(exp, "static int foo(void);\n");
    exp = string_concat(exp, "\n");
    exp = string_concat(exp, "static int foo(void) {\n  return 1;\n}\n\n");
    exp = string_concat(exp, "int main(void) { return 0; }\n");
    if !string_eq(s, exp) { return 1; }
    return 0;
}

