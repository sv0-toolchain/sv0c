# Pilot sources for `./scripts/sv0 self-host-sv0-loop` (paths relative to sv0c/).
# Each file must define fn main() -> i32 and exit 0 when compiled to C and run natively.
# Only include seeds whose emitted C links as a single translation unit today (some slices
# still emit C that is golden-checked but not yet ABI-clean for cc — see doc).
# Expand this list as the C backend hardens; keep CI time reasonable.

lib/span_core.sv0
lib/lower_unop_core.sv0
lexer/token_keyword_core.sv0
parser/expr_entry_core.sv0
parser/stmt_entry_core.sv0
