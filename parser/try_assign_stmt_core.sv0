fn rhs_stub_ok_with_semi(t0: i32, t1: i32, t2: i32, t3: i32) -> i32 {
  if t0 == 40 {
    if t1 == 15 {
      return 1;
    } else {
      if t1 == 20 {
        if t2 == 40 {
          if t3 == 15 {
            return 1;
          } else {
            return 0;
          }
        } else {
          return 0;
        }
      } else {
        return 0;
      }
    }
  } else {
    if t0 == 73 {
      if t1 == 15 {
        return 1;
      } else {
        return 0;
      }
    } else {
      return 0;
    }
  }
}

fn pratt_is_atom(t: i32) -> i32 {
  if t == 40 {
    return 1;
  } else {
    if t == 73 {
      return 1;
    } else {
      return 0;
    }
  }
}

fn pratt_is_add_binop(t: i32) -> i32 {
  if t == 20 {
    return 1;
  } else {
    if t == 21 {
      return 1;
    } else {
      return 0;
    }
  }
}

/* Duplicated from **parser/expr_pratt_stub_core.sv0**; see that file for shapes, unary **21**, binary add tier **20**, **21**. */
fn pratt_from_atom(a: i32, t1: i32, t2: i32, t3: i32, t4: i32, t5: i32) -> i32 {
  if pratt_is_atom(a) == 0 {
    return 0;
  } else {
    if t1 == 15 {
      return 1;
    } else {
      if pratt_is_add_binop(t1) == 1 {
        if pratt_is_atom(t2) == 0 {
          return 0;
        } else {
          if t3 == 15 {
            return 1;
          } else {
            if t3 == 22 {
              if pratt_is_atom(t4) == 0 {
                return 0;
              } else {
                if t5 == 15 {
                  return 1;
                } else {
                  return 0;
                }
              }
            } else {
              return 0;
            }
          }
        }
      } else {
        if t1 == 22 {
          if pratt_is_atom(t2) == 0 {
            return 0;
          } else {
            if t3 == 15 {
              return 1;
            } else {
              if t3 == 22 {
                if pratt_is_atom(t4) == 0 {
                  return 0;
                } else {
                  if t5 == 15 {
                    return 1;
                  } else {
                    return 0;
                  }
                }
              } else {
                if pratt_is_add_binop(t3) == 1 {
                  if pratt_is_atom(t4) == 0 {
                    return 0;
                  } else {
                    if t5 == 15 {
                      return 1;
                    } else {
                      return 0;
                    }
                  }
                } else {
                  return 0;
                }
              }
            }
          }
        } else {
          return 0;
        }
      }
    }
  }
}

fn pratt_rhs_ok_with_semi7(t0: i32, t1: i32, t2: i32, t3: i32, t4: i32, t5: i32, t6: i32) -> i32 {
  if pratt_is_atom(t0) == 1 {
    return pratt_from_atom(t0, t1, t2, t3, t4, t5);
  } else {
    if t0 == 21 {
      if pratt_is_atom(t1) == 0 {
        return 0;
      } else {
        return pratt_from_atom(t1, t2, t3, t4, t5, t6);
      }
    } else {
      return 0;
    }
  }
}

fn pratt_rhs_ok_with_semi(t0: i32, t1: i32, t2: i32, t3: i32, t4: i32, t5: i32) -> i32 {
  return pratt_rhs_ok_with_semi7(t0, t1, t2, t3, t4, t5, 0);
}

fn assign_binop_ast_tag(t: i32) -> i32 {
  if t == 211 {
    return 1;
  } else {
    if t == 212 {
      return 2;
    } else {
      if t == 213 {
        return 3;
      } else {
        if t == 214 {
          return 4;
        } else {
          if t == 215 {
            return 5;
          } else {
            if t == 216 {
              return 6;
            } else {
              if t == 217 {
                return 7;
              } else {
                if t == 218 {
                  return 8;
                } else {
                  if t == 219 {
                    return 9;
                  } else {
                    if t == 220 {
                      return 10;
                    } else {
                      return 0;
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}

fn assign_op_follows_lhs(t: i32) -> i32 {
  if t == 19 {
