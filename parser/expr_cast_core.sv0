  let bad_third_as: i32 =
    parse_cast_stub_ok_with_semi6(
      tok_int_lit(),
      tok_as_kw(),
      tok_ident(),
      tok_as_kw(),
      tok_ident(),
      tok_as_kw()
    );
  let e5: i32 =
    bad_mul + bad_ty_lit + bad_no_semi + bad_as_first + bad_second_ty_lit + bad_third_as;
  return e0 + e1 + e2 + e3 + e4 + e5;
