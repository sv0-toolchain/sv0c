enum Expr { Lit(i32), Add(Box<Expr>, Box<Expr>) }

fn eval(e: Expr) -> i32 {
    match e {
        Expr::Lit(n) => n,
        Expr::Add(l, r) => {
            let le: Expr = box_deref(l);
            let re: Expr = box_deref(r);
            return eval(le) + eval(re);
        },
    }
}

fn main() -> i32 {
    let lit1: Expr = Expr::Lit(2);
    let lit2: Expr = Expr::Lit(3);
    let b1: Box<Expr> = box_new(lit1);
    let b2: Box<Expr> = box_new(lit2);
    let add: Expr = Expr::Add(b1, b2);
    let res: i32 = eval(add);
    if res == 5 { return 0; };
    return 1;
}
